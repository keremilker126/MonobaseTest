@using System.Text.Encodings.Web
@model List<Notes>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<style>
/* Genel Sayfa Ayarları */
body {
    background: #f0f2f5; /* Daha modern bir gri-mavi tonu */
    font-family: 'Inter', -apple-system, sans-serif;
    color: #334155;
}

/* Başlık Alanı */
h3.fw-bold {
    letter-spacing: -1px;
    margin-top: 2rem;
    color: #1e293b !important;
}

/* Kart Genel Tasarımı */
.card {
    border-radius: 24px !important;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Yeni Not Ekleme Kartı (Sticky Yapma) */
/* Eğer formun sayfa kaydıkça yanında kalmasını istersen col-md-7'yi 
   daraltıp yanına koyabilirsin ama mevcut yapıda şu an en tepede şık duruyor. */
form .form-control {
    transition: background-color 0.3s ease;
}

form .form-control:focus {
    background-color: #fff !important;
    box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1) !important;
}

/* Not Kartları Tasarımı */
.note-card {
    border-left: 6px solid #0d6efd !important; /* Çizgiyi biraz kalınlaştırdık */
    background: #ffffff;
    cursor: default;
}

.note-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
}

/* İkon Butonları (Düzenle ve Sil) */
.btn-outline-primary, .btn-outline-danger {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px !important;
    transition: all 0.2s ease;
}

.btn-outline-primary:hover {
    background-color: rgba(13, 110, 253, 0.1);
    color: #0d6efd;
    transform: scale(1.1);
}

.btn-outline-danger:hover {
    background-color: rgba(220, 53, 69, 0.1);
    color: #dc3545;
    transform: scale(1.1);
}

/* Badge ve ID Alanı */
.badge.bg-light {
    background-color: #f1f5f9 !important;
    color: #64748b !important;
    font-weight: 600;
    padding: 8px 16px;
}

code.small {
    background: #f8fafc;
    padding: 4px 8px;
    border-radius: 6px;
    color: #94a3b8 !important;
}

/* Modal Modernizasyonu */
.modal-content {
    border: none;
    overflow: hidden;
}

.modal-header {
    background: #fff;
    padding: 25px 30px 10px;
}

.modal-body {
    padding: 20px 30px;
}

.modal-footer {
    padding: 10px 30px 30px;
}

.modal .form-control {
    padding: 12px 15px;
    border-radius: 12px;
}

/* Kaydet/Güncelle Butonları Animasyonu */
.btn-primary {
    background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
    border: none;
    box-shadow: 0 4px 12px rgba(13, 110, 253, 0.25);
}

.btn-primary:hover {
    box-shadow: 0 6px 15px rgba(13, 110, 253, 0.35);
    transform: translateY(-1px);
}
</style>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h3 class="fw-bold mb-4 text-dark text-center">📝 Not Defterim</h3>

            <div class="card shadow-sm border-0 mb-5" style="border-radius: 20px; background: #ffffff;">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <input type="text" name="title" class="form-control border-0 mb-2 fw-bold text-primary"
                               placeholder="Başlık ekleyin..." required style="font-size: 1.3rem; box-shadow: none;">
                        <textarea name="content" class="form-control border-0 mb-3"
                                  placeholder="Notunuzu buraya yazın..." rows="4" required
                                  style="resize: none; box-shadow: none; color: #555;"></textarea>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary fw-bold py-2 rounded-pill shadow-sm">
                                <i class="fa-solid fa-save me-2"></i>Notu Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="row g-3">
                @if (Model == null || !Model.Any())
                {
                    <div class="text-center text-muted mt-5">
                        <i class="fa-regular fa-note-sticky fa-3x mb-3"></i>
                        <p>Henüz hiç not eklenmemiş.</p>
                    </div>
                }
                else
                {
                    @foreach (var note in Model)
                    {
                        <div class="col-12">
                            <div class="card border-0 shadow-sm note-card" style="border-radius: 15px; border-left: 5px solid #0d6efd !important;">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="fw-bold mb-0 text-dark">@note.Title</h5>
                                        
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary border-0" 
                                                    onclick="openEditModal('@note.Id', '@JavaScriptEncoder.Default.Encode(note.Title)', '@JavaScriptEncoder.Default.Encode(note.Content)')">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>

                                            <form asp-action="Delete" method="post" onsubmit="return confirm('Silinsin mi?');">
                                                <input type="hidden" name="id" value="@note.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger border-0">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>

                                    <p class="text-secondary mb-3" style="white-space: pre-line;">@note.Content</p>
                                    
                                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                        <code class="small text-muted" style="font-size: 0.75rem;">ID: @note.Id</code>
                                        <span class="badge rounded-pill bg-light text-primary border small">MonoBase</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold">Notu Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="edit-id" />
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">Başlık</label>
                        <input type="text" name="title" id="edit-title" class="form-control border-0 bg-light fw-bold" required style="border-radius: 10px;">
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">İçerik</label>
                        <textarea name="content" id="edit-content" class="form-control border-0 bg-light" rows="5" required style="border-radius: 10px; resize: none;"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openEditModal(id, title, content) {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-title').value = title;
        document.getElementById('edit-content').value = content;
        new bootstrap.Modal(document.getElementById('editModal')).show();
    }
</script>

<style>
    body { background-color: #f4f7f6; font-family: 'Segoe UI', Roboto, sans-serif; }
    .note-card { transition: all 0.3s ease; background: #ffffff; }
    .note-card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important; }
</style>